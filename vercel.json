{
  "version": 2,
  "functions": {
    "api.js": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/api.js"
    },
    {
      "src": "/api",
      "dest": "/api.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api.js"
    },
    {
      "src": "/skins",
      "dest": "/api.js"
    },
    {
      "src": "/menu",
      "dest": "/api.js"
    },
    {
      "src": "/(.*)\\.(js|json|so|dat|pak)",
      "dest": "/api.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api.js"
    }
  ]
}