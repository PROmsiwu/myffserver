{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "webview.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/server.js"
    },
    {
      "src": "/webview",
      "dest": "/webview.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}